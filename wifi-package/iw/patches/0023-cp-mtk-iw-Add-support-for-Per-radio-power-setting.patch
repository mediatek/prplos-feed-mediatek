From ee4cc7b103ea3415dc50de486c39a454b4e0f211 Mon Sep 17 00:00:00 2001
From: Shayne Chen <shayne.chen@mediatek.com>
Date: Tue, 26 Aug 2025 15:05:24 +0800
Subject: [PATCH] mtk: iw: Add support for Per-radio power setting

Sync nl80211.h for NL80211_ATTR_WIPHY_RADIO_INDEX

Revert "iw: add per-link txpower config"
mtk: iw: support per-radio txpower setting

Valid commands for non-single-multi-radio wiphy:
iw phy phy0 set txpower fixed 1600 (argc = 2)
iw phy phy0 set txpower auto (argc = 1)

Valid commands for single-multi-radio wiphy:
iw phy phy0 set txpower fixed 1600 radio 0 (argc = 4)
iw phy phy0 set txpower auto radio 0 (argc = 3)

Example commands for single-multi-radio wiphy:
iw phy phy0 set txpower fixed 1600 radio 0
iw phy phy0 set txpower fixed 1600 radio 1
iw phy phy0 set txpower fixed 1000 radio 2
iw phy phy0 set txpower auto radio 0
iw phy phy0 set txpower auto radio 1
iw phy phy0 set txpower auto radio 2

Signed-off-by: Shayne Chen <shayne.chen@mediatek.com>
---
 ieee80211.h |  2 +-
 interface.c |  6 +++---
 nl80211.h   | 10 ++++++++++
 phy.c       | 55 +++++++++++++++++++++++++++--------------------------
 4 files changed, 42 insertions(+), 31 deletions(-)

diff --git a/ieee80211.h b/ieee80211.h
index 20d3ec1..af84cb8 100644
--- a/ieee80211.h
+++ b/ieee80211.h
@@ -119,6 +119,6 @@ enum elem_id_ext {
 #define WLAN_CIPHER_SUITE_BIP_CMAC_256  SUITE(0x000FAC, 13)
 
 /* multi-link device */
-#define IEEE80211_MLD_MAX_NUM_LINKS	15
+#define IEEE80211_MLD_MAX_NUM_LINKS    15
 
 #endif /* __IEEE80211 */
diff --git a/interface.c b/interface.c
index bfa596c..84f69b1 100644
--- a/interface.c
+++ b/interface.c
@@ -452,7 +452,6 @@ static int print_iface_handler(struct nl_msg *msg, void *arg)
 	struct nlattr *tb_msg[NL80211_ATTR_MAX + 1];
 	unsigned int *wiphy = arg;
 	const char *indent = "";
-	int32_t txp;
 
 	nla_parse(tb_msg, NL80211_ATTR_MAX, genlmsg_attrdata(gnlh, 0),
 		  genlmsg_attrlen(gnlh, 0), NULL);
@@ -496,7 +495,8 @@ static int print_iface_handler(struct nl_msg *msg, void *arg)
 	}
 
 	if (tb_msg[NL80211_ATTR_WIPHY_TX_POWER_LEVEL]) {
-		txp = nla_get_u32(tb_msg[NL80211_ATTR_WIPHY_TX_POWER_LEVEL]);
+		int32_t txp = nla_get_u32(tb_msg[NL80211_ATTR_WIPHY_TX_POWER_LEVEL]);
+
 		printf("%s\ttxpower %d.%.2d dBm\n",
 		       indent, txp / 100, txp % 100);
 	}
@@ -537,7 +537,7 @@ static int print_iface_handler(struct nl_msg *msg, void *arg)
 				print_channel(tb);
 			}
 			if (tb[NL80211_ATTR_WIPHY_TX_POWER_LEVEL]) {
-				txp = nla_get_u32(tb[NL80211_ATTR_WIPHY_TX_POWER_LEVEL]);
+				int32_t txp = nla_get_u32(tb[NL80211_ATTR_WIPHY_TX_POWER_LEVEL]);
 
 				printf("\n%s\t   txpower %d.%.2d dBm", indent, txp / 100, txp % 100);
 			}
diff --git a/nl80211.h b/nl80211.h
index 6fa52eb..256ef39 100644
--- a/nl80211.h
+++ b/nl80211.h
@@ -2931,6 +2931,14 @@ enum nl80211_commands {
  * @NL80211_ATTR_CRTI_UPDATE_EVENT: Type of critical update event for notification
  *	to userspace, contains a value of enum nl80211_crit_update_event (u8).
  *
+ * @NL80211_ATTR_WIPHY_RADIO_INDEX: (int) Integer attribute denoting the index
+ *	of the radio in interest. Internally a value of -1 is used to
+ *	indicate that the radio id is not given in user-space. This means
+ *	that all the attributes are applicable to all the radios. If there is
+ *	a radio index provided in user-space, the attributes will be
+ *	applicable to that specific radio only. If the radio id is greater
+ *	thank the number of radios, error denoting invalid value is returned.
+ *
  * @NUM_NL80211_ATTR: total number of nl80211_attrs available
  * @NL80211_ATTR_MAX: highest attribute number currently defined
  * @__NL80211_ATTR_AFTER_LAST: internal use
@@ -3488,6 +3496,8 @@ enum nl80211_attrs {
 
 	NL80211_ATTR_ASSOC_MLD_EXT_CAPA_OPS,
 
+	NL80211_ATTR_WIPHY_RADIO_INDEX,
+
 	/* add attributes here, update the policy in nl80211.c */
 
 	/* MTK internal */
diff --git a/phy.c b/phy.c
index f9a5b0f..8eaaad5 100644
--- a/phy.c
+++ b/phy.c
@@ -686,62 +686,63 @@ static int handle_txpower(struct nl80211_state *state,
 			  enum id_input id)
 {
 	enum nl80211_tx_power_setting type;
-	unsigned int link_id;
-	int mbm, pos = 0;
 	char *endptr;
+	int mbm;
 
-	/* check args number */
-	if (argc < 1 && argc > 4)
+	/* get the required args */
+	if (argc <= 0 && argc > 4)
 		return 1;
 
-	if (!strcmp(argv[0], "-l")) {
-		link_id = strtol(argv[1], &endptr, 10);
-		if (*endptr)
-			return 1;
-
-		if (link_id >= IEEE80211_MLD_MAX_NUM_LINKS) {
-			printf("link id %d exceeds max number of links\n", link_id);
-			return 2;
-		}
-		NLA_PUT_U8(msg, NL80211_ATTR_MLO_LINK_ID, link_id);
-		pos += 2;
-	}
-
-	if (!strcmp(argv[pos], "auto"))
+	if (!strcmp(argv[0], "auto"))
 		type = NL80211_TX_POWER_AUTOMATIC;
-	else if (!strcmp(argv[pos], "fixed"))
+	else if (!strcmp(argv[0], "fixed"))
 		type = NL80211_TX_POWER_FIXED;
-	else if (!strcmp(argv[pos], "limit"))
+	else if (!strcmp(argv[0], "limit"))
 		type = NL80211_TX_POWER_LIMITED;
 	else {
-		printf("Invalid parameter: %s\n", argv[pos]);
+		printf("Invalid parameter: %s\n", argv[0]);
 		return 2;
 	}
 
 	NLA_PUT_U32(msg, NL80211_ATTR_WIPHY_TX_POWER_SETTING, type);
 
+	argv++;
+	argc--;
+
 	if (type != NL80211_TX_POWER_AUTOMATIC) {
-		if (argc < 2 + pos) {
+		if (argc != 1 && argc != 3) {
 			printf("Missing TX power level argument.\n");
 			return 2;
 		}
 
-		mbm = strtol(argv[pos + 1], &endptr, 10);
-		if (*endptr)
+		mbm = strtol(argv[0], &endptr, 10);
+		if (argc == 1 && *endptr)
 			return 2;
 		NLA_PUT_U32(msg, NL80211_ATTR_WIPHY_TX_POWER_LEVEL, mbm);
-	} else if (argc != 1 + pos)
+
+		argv++;
+		argc--;
+	} else if (argc != 0 && argc != 2)
 		return 1;
 
+	if (argc == 2 && strcmp("radio", argv[0]) == 0) {
+		unsigned int radio_idx = strtoul(argv[1], &endptr, 10);
+
+		if (*endptr)
+			return 2;
+
+		NLA_PUT_U8(msg, NL80211_ATTR_WIPHY_RADIO_INDEX, radio_idx);
+	}
+
 	return 0;
 
  nla_put_failure:
 	return -ENOBUFS;
 }
-COMMAND(set, txpower, "<auto|fixed|limit> [<tx power in mBm>]",
+COMMAND(set, txpower, "<auto|fixed|limit> [<tx power in mBm>] [radio <radio index>]",
 	NL80211_CMD_SET_WIPHY, 0, CIB_PHY, handle_txpower,
 	"Specify transmit power level and setting type.");
-COMMAND(set, txpower, "[-l <link_id>] <auto|fixed|limit> [<tx power in mBm>]",
+COMMAND(set, txpower, "<auto|fixed|limit> [<tx power in mBm>]",
 	NL80211_CMD_SET_WIPHY, 0, CIB_NETDEV, handle_txpower,
 	"Specify transmit power level and setting type.");
 
-- 
2.45.2

