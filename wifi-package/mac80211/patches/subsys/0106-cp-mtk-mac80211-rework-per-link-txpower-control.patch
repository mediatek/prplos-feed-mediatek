-
-		link_conf = link->conf;
 
 		if (sdata->vif.type == NL80211_IFTYPE_MONITOR &&
 		    !ieee80211_hw_check(&local->hw, NO_VIRTUAL_MONITOR)) {
@@ -3150,10 +3147,8 @@ static int ieee80211_set_tx_power(struct wiphy *wiphy,
