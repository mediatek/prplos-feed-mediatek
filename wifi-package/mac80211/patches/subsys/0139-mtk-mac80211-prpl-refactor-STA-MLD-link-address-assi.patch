From 71634b27272666a95082129919f68a7c7bf63c84 Mon Sep 17 00:00:00 2001
From: Benjamin Lin <benjamin-jw.lin@mediatek.com>
Date: Thu, 19 Mar 2026 19:10:12 +0800
Subject: [PATCH] mtk: mac80211: prpl: refactor STA MLD link-address assignment
 to follow prplOS default rule

Follow prplOS default rule to assign link addresses of STA MLD.
Otherwise, STA MLD cannot be created successfully.
Still, flexible link-address setting via pwhm by user is not yet supported.

Signed-off-by: Benjamin Lin <benjamin-jw.lin@mediatek.com>
---
 net/mac80211/mlme.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/net/mac80211/mlme.c b/net/mac80211/mlme.c
index a215d07..8ad55f3 100644
--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -9204,8 +9204,10 @@ void ieee80211_mgd_setup_link(struct ieee80211_link_data *link)
 	else if (sdata->u.mgd.reconf.add_links_data)
 		ether_addr_copy(link->conf->addr,
 				sdata->u.mgd.reconf.add_links_data->link[link_id].addr);
-	else if (!is_valid_ether_addr(link->conf->addr))
+	else if (!is_valid_ether_addr(link->conf->addr)) {
 		ether_addr_copy(link->conf->addr, sdata->vif.addr);
+		link->conf->addr[5] += link_id;
+	}
 }
 
 /* scan finished notification */
@@ -10068,7 +10070,7 @@ int ieee80211_mgd_assoc(struct ieee80211_sub_if_data *sdata,
 						link->conf->addr);
 			} else {
 				ether_addr_copy(assoc_data->link[i].addr, sdata->vif.addr);
-				assoc_data->link[i].addr[4] += i + 1;
+				assoc_data->link[i].addr[5] += i;
 			}
 			sband = local->hw.wiphy->bands[link_cbss->channel->band];
 
-- 
