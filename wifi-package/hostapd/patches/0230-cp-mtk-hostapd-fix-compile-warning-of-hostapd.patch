-int hostapd_drv_set_eml_omn(struct hostapd_data *hapd, u8 *mac,
+int hostapd_drv_set_eml_omn(struct hostapd_data *hapd, const u8 *mac,
 			    struct eml_omn_element *omn_ie)
 {
 	u8 link_id;
@@ -1726,11 +1726,26 @@ int hostapd_drv_set_eml_omn(struct hostapd_data *hapd, u8 *mac,
 int hostapd_drv_set_epcs(struct hostapd_data *hapd, struct epcs_entry *entry,
 			 struct mld_info *mld)
 {
+	struct hapd_interfaces *ifaces = hapd->iface->interfaces;
+	int i, ret;
+
 	if (!hapd->driver || !hapd->driver->set_epcs || !hapd->conf->mld_ap)
 		return -EOPNOTSUPP;
 
-	return hapd->driver->set_epcs(hapd->drv_priv, hapd->iface->interfaces,
-				      entry, mld->links, mld->epcs.enabled);
+	for (i = 0; i < MAX_NUM_MLD_LINKS; i++) {
+		u16 wmm_idx = entry->wmm_idx[i];
+
+		if (!mld->links[i].valid)
+			continue;
+
+		ret = hapd->driver->set_epcs(hapd->drv_priv, entry->addr, i,
+					     mld->epcs.enabled, wmm_idx,
+					     ifaces->epcs.wmm_tbl[wmm_idx]);
+		if (ret)
+			return ret;
+	}
+
+	return ret;
 }
 
