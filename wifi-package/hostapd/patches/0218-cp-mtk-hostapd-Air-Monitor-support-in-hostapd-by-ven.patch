From 2b2c73685e41d626147b471a4d1cc4b38867ba6f Mon Sep 17 00:00:00 2001
From: Peter Chiu <chui-hao.chiu@mediatek.com>
Date: Mon, 30 Jun 2025 19:34:24 +0800
Subject: [PATCH] cp: mtk: hostapd: Air Monitor support in hostapd by vendor

Use sizeof struct amnt_resp_data instead of plus one directly.
It may lead to hostapd crash without this patch.

Signed-off-by: Peter Chiu <chui-hao.chiu@mediatek.com>
---
 hostapd/ctrl_iface.c | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 07c222edf..349bcfac7 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -5417,7 +5417,7 @@ hostapd_ctrl_iface_dump_amnt(struct hostapd_data *hapd, char *cmd,
 				char *buf, size_t buflen)
 {
 	char *tmp;
-	int amnt_idx = 0, ret = 0;
+	int amnt_idx = 0, ret = 0, resp_buf_len = sizeof(struct amnt_resp_data);
 	struct amnt_resp_data *resp_buf;
 	char *pos, *end;
 	struct amnt_data *res;
@@ -5439,11 +5439,11 @@ hostapd_ctrl_iface_dump_amnt(struct hostapd_data *hapd, char *cmd,
 		return -1;
 	}
 
-	if (amnt_idx == 0xff)
-		resp_buf = (struct amnt_resp_data *) os_zalloc(AIR_MONITOR_MAX_ENTRY
-							* sizeof(struct amnt_data) + 1);
-	else
-		resp_buf = (struct amnt_resp_data *) os_zalloc(sizeof(struct amnt_data) + 1);
+	resp_buf_len += (amnt_idx == 0xff) ?
+			AIR_MONITOR_MAX_ENTRY * sizeof(struct amnt_data) :
+			sizeof(struct amnt_data);
+
+	resp_buf = (struct amnt_resp_data *) os_zalloc(resp_buf_len);
 
 	if (resp_buf == NULL) {
 		wpa_printf(MSG_ERROR, "Error in memory allocation\n");
-- 
