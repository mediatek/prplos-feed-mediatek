From 45016e966909dc147d1419b8d3fd3344ce0f2e8a Mon Sep 17 00:00:00 2001
From: Allen Ye <allen.ye@mediatek.com>
Date: Mon, 14 Jul 2025 15:29:16 +0800
Subject: [PATCH 223/226] mtk: hostapd: Refactor aid allocation

Fix non-tx bss should use tx hapd aid pool to free sta aid.

Signed-off-by: Allen Ye <allen.ye@mediatek.com>
Signed-off-by: Peter Chiu <chui-hao.chiu@mediatek.com>
---
 src/ap/sta_info.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/src/ap/sta_info.c b/src/ap/sta_info.c
index 80f75e3e9..d7f0e3657 100644
--- a/src/ap/sta_info.c
+++ b/src/ap/sta_info.c
@@ -274,9 +274,11 @@ void ap_free_sta(struct hostapd_data *hapd, struct sta_info *sta)
 	ap_sta_hash_del(hapd, sta);
 	ap_sta_list_del(hapd, sta);
 
-	if (sta->aid - 64 > 0)
-		hapd->sta_aid[(sta->aid - 1 - 64) / 32] &=
+	if (sta->aid - 64 > 0) {
+		struct hostapd_data *tx_bss = hostapd_mbssid_get_tx_bss(hapd);
+		tx_bss->sta_aid[(sta->aid - 1 - 64) / 32] &=
 			~BIT((sta->aid - 1 - 64) % 32);
+	}
 
 	hapd->num_sta--;
 	if (sta->nonerp_set) {
-- 
2.45.2

