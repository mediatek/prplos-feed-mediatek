From 288ad871d4020403c18a7434e29e660597477513 Mon Sep 17 00:00:00 2001
From: Shayne Chen <shayne.chen@mediatek.com>
Date: Mon, 8 Sep 2025 12:16:15 +0800
Subject: [PATCH 09/10] mtk: mt76: mt7996: fixup the mlo tp downgrade during AP
 scan.

Correctly do calibration when switching back to working channel during
scanning.

Signed-off-by: Shayne Chen <shayne.chen@mediatek.com>
---
 mt7996/mcu.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/mt7996/mcu.c b/mt7996/mcu.c
index bfbe9d10..bdb1fd71 100644
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -5577,8 +5577,7 @@ int mt7996_mcu_set_chan_info(struct mt7996_phy *phy, u16 tag, bool sta)
 	if (phy->mt76->hw->conf.flags & IEEE80211_CONF_MONITOR)
 		req.switch_reason = CH_SWITCH_NORMAL;
 	else if (phy->mt76->offchannel ||
-		 phy->mt76->hw->conf.flags & IEEE80211_CONF_IDLE ||
-		 test_bit(MT76_SCANNING, &phy->mt76->state))
+		 phy->mt76->hw->conf.flags & IEEE80211_CONF_IDLE)
 		req.switch_reason = CH_SWITCH_SCAN_BYPASS_DPD;
 	else if (!cfg80211_reg_can_beacon(phy->mt76->hw->wiphy, chandef, iftype))
 		req.switch_reason = CH_SWITCH_DFS;
-- 
