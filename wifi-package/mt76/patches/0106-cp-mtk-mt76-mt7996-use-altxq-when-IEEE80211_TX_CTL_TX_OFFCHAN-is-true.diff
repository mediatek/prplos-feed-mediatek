From b11dac268210fa8f6cabd8a9406d03b5413ea912 Mon Sep 17 00:00:00 2001
From: Peter Chiu <chui-hao.chiu@mediatek.com>
Date: Wed, 04 Jun 2025 16:42:10 +0800
Subject: [PATCH] mtk: mt76: mt7996: use altxq when IEEE80211_TX_CTL_TX_OFFCHAN is true

CR-Id: WCNCR00240772
Signed-off-by: Peter Chiu <chui-hao.chiu@mediatek.com>
Change-Id: I50bff57319007fba2362d8c3429f667242ba8709
---

diff --git a/mt7996/mac.c b/mt7996/mac.c
index 15e3f24..68768e7 100644
--- a/mt7996/mac.c
+++ b/mt7996/mac.c
@@ -760,10 +760,15 @@
 		txwi[3] |= cpu_to_le32(MT_TXD3_HW_AMSDU);
 }
 
-static bool mt7996_is_skb_altx(struct ieee80211_mgmt *mgmt)
+static bool mt7996_is_skb_altx(struct ieee80211_mgmt *mgmt,
+			       struct ieee80211_tx_info *info)
 {
 	__le16 fc = mgmt->frame_control;
 
+	/* Frames sent in off-chan should be transmitted immediately */
+	if (info->flags & IEEE80211_TX_CTL_TX_OFFCHAN)
+		return true;
+
 	if (ieee80211_is_deauth(fc)) {
 		/* In WPA3 cert TC-4.8.1, the deauth must be transmitted without
 		 * considering PSM bit
@@ -800,7 +805,7 @@
 	u8 fc_type, fc_stype;
 	u32 val;
 
-	if (mt7996_is_skb_altx(mgmt)) {
+	if (mt7996_is_skb_altx(mgmt, info)) {
 		txwi[0] &= ~cpu_to_le32(MT_TXD0_Q_IDX);
 		txwi[0] |= cpu_to_le32(FIELD_PREP(MT_TXD0_Q_IDX, MT_LMAC_ALTX0));
 	}
